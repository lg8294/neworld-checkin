# 必填：账号列表 JSON（单行，勿换行）。GitHub Actions 里可复制到 Secret ACCOUNTS_JSON
# 示例：[{"email":"you@example.com","password":"your-password"}]
ACCOUNTS_JSON=

# 必填：登录请求中的 fingerprint（与站点要求一致）
NEWORD_FINGERPRINT=

# 钉钉机器人（可选；不填则仅控制台输出通知内容）
DINGTALK_WEBHOOK=
# 使用加签机器人时必填，且需与 DINGTALK_WEBHOOK 同时配置
DINGTALK_SECRET=

# HTTP 代理（可选）
# HTTP_PROXY=http://127.0.0.1:8888
